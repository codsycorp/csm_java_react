# PROFILE: server yếu 5GB — KHÔNG dùng trên máy dev mạnh
#
# Server (jar, từ repo root):
#   ./run-server.sh
#   hoặc: set -a && source config.local-5gb.env && set +a && ./start.sh
#
# Tự nạp config.env nếu có.

if [ -n "${BASH_SOURCE[0]:-}" ]; then
    _CSM_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -f "$_CSM_CONFIG_DIR/config.env" ]; then
        # shellcheck source=/dev/null
        source "$_CSM_CONFIG_DIR/config.env"
    fi
    unset _CSM_CONFIG_DIR
fi

CSM_LOCAL_PROFILE=5gb
SPRING_PROFILES_ACTIVE_OVERRIDE=prod,local-5gb
AI_LOCAL_MODE=5gb
AI_LOCAL_RUNTIME_TIER=weak-5gb

# JVM (server 5–6GB total RAM)
HEAP_SIZE=1536m
HEAP_INIT=384m
DIRECT_MEMORY_SIZE=128m
TOMCAT_MAX_THREADS=24
TOMCAT_MAX_CONNECTIONS=120
ENABLE_ALWAYS_PRETOUCH=false

# Local-only routing
AI_LOCAL_ONLY_ENABLED=true
AI_PROVIDER_FORCE_GEMINI=false
AI_ROUTER_SCORE_V2_MENU_JSON_CLOUD=false

# Model: 1.5B Q4 — ghi đè config.env (tránh trỏ nhầm VL/vision model trên server yếu)
AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q4_k_m.gguf

# LLM bounded for 5GB (Spring env → application-local-5gb.properties)
AI_LOCAL_LLAMA_RUNTIME_PROFILE=balanced
AI_LOCAL_LLAMA_CONTEXT_WINDOW=8192
AI_LOCAL_LLAMA_MAX_TOKENS=768
AI_LOCAL_LLAMA_MAX_PROMPT_CHARS=32000
AI_LOCAL_LLAMA_THREADS=1
AI_LOCAL_LLAMA_BATCH_SIZE=32
AI_LOCAL_LLAMA_UBATCH_SIZE=16
AI_LOCAL_LLAMA_MAX_CONCURRENT_REQUESTS=1
AI_LOCAL_LLAMA_PRELOAD_ON_STARTUP=false
AI_LOCAL_LLAMA_FORCE_SINGLE_THREAD_ON_WEAK=true

AI_EMBEDDING_LLAMA_THREADS=1
AI_EMBEDDING_LLAMA_BATCH_SIZE=256
AI_EMBEDDING_LLAMA_UBATCH_SIZE=128
# Weak 5GB: hash embedding (128D) — tránh dùng qwen chat model (1536D) gây lỗi Lucene index
AI_EMBEDDING_PROVIDER=hash
AI_EMBEDDING_LLAMA_ENABLED=false
AI_EMBEDDING_HASH_DIMENSIONS=128
AI_EMBEDDING_HASH_FALLBACK_ENABLED=true

# Prompt / RAG caps (Cursor-style small context)
AI_LOCAL_PROMPT_SLOT_ACTIVE_EDITOR_CHARS=14000
AI_LOCAL_PROMPT_SLOT_RAG_CONTEXT_CHARS=2800
AI_CODE_STREAM_LOCAL_PROVIDER_MAX_PROMPT_CHARS=32000
AI_CODE_STREAM_MAX_PROMPT_CHARS=36000

AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_TOP_K=3
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_MAX_CHARS=2800
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ADAPTIVE_MAX_MAX_CHARS=2800
AI_ORCHESTRATION_SPECULATIVE_ENABLED=false

# Edit fast path on weak
AI_CODE_STREAM_STEP_OUTPUT_CONTRACT_STRICT_EDIT=false
AI_CODE_STREAM_EDIT_STRICT_SEARCH_REPLACE_ENABLED=false
AI_LOCAL_AGENTIC_STEP_VERIFIER_ENABLED=false
AI_LOCAL_EVIDENCE_GATE_ENABLED=false

# Large DynamicCode → async Lucene vector chunk ingest (see CSM_AI_LOCAL_CURSOR_MASTER_BRIEF.md §N)
AI_CONTEXT_INGESTION_LARGE_CODE_ENABLED=true
AI_CONTEXT_INGESTION_LARGE_CODE_THRESHOLD_CHARS=45000
AI_CONTEXT_INGESTION_LARGE_CODE_MAX_CHARS=600000

# Vision — sidecar on-demand (see scripts/start-ai-local-vision.sh + PHẦN Q master brief)
# Bật CHỈ khi đã chạy: ./scripts/start-ai-local-vision.sh
AI_ORCHESTRATION_MULTIMODAL_VISION_ENABLED=false
AI_ORCHESTRATION_MULTIMODAL_VISION_ENDPOINT=http://127.0.0.1:8091/
AI_ORCHESTRATION_MULTIMODAL_VISION_TIMEOUT_MS=12000
AI_ORCHESTRATION_MULTIMODAL_LOCAL_ONLY_REQUIRE_VISION=false
# Vision GGUF (sidecar, NOT Spring JVM): SmolVLM2-256M-Video Q8_0 + mmproj (~279MB)

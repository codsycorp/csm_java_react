# PROFILE: Linux server production ~5–6GB RAM (PHẦN Q)
#
# Text worker: 1 GGUF — qwen2.5-coder-1.5b-instruct-q8_0.gguf
# Launch: ./run-server.sh
# Model: ./scripts/download-ai-local-models.sh server

if [ -n "${BASH_SOURCE[0]:-}" ]; then
    _CSM_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -f "$_CSM_CONFIG_DIR/config.env" ]; then
        # shellcheck source=/dev/null
        source "$_CSM_CONFIG_DIR/config.env"
    fi
    unset _CSM_CONFIG_DIR
fi

CSM_LOCAL_PROFILE=5gb
SPRING_PROFILES_ACTIVE_OVERRIDE=prod,local-5gb
AI_LOCAL_MODE=5gb
AI_LOCAL_RUNTIME_TIER=weak-5gb

# JVM (~1.25GB heap + ~1.6–2.0GB native 1.5B Q8_0 + OS)
HEAP_SIZE=1280m
HEAP_INIT=256m
DIRECT_MEMORY_SIZE=96m
TOMCAT_MAX_THREADS=16
TOMCAT_MAX_CONNECTIONS=80
ENABLE_ALWAYS_PRETOUCH=false

AI_LOCAL_ONLY_ENABLED=true
AI_PROVIDER_FORCE_GEMINI=false
AI_ROUTER_SCORE_V2_MENU_JSON_CLOUD=false

# Single worker 1.5B Q8_0 — code + SEO + guest chat
AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
AI_LOCAL_LLAMA_SEO_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
AI_LOCAL_LLAMA_SWAP_MODELS=false

AI_LOCAL_LLAMA_RUNTIME_PROFILE=conservative
AI_LOCAL_LLAMA_CONTEXT_WINDOW=8192
AI_LOCAL_LLAMA_CONTEXT_WINDOW_AUTO_FIT=true
AI_LOCAL_LLAMA_CONTEXT_WINDOW_HARD_CAP=8192
AI_LOCAL_LLAMA_MAX_TOKENS=512
AI_LOCAL_LLAMA_MAX_PROMPT_CHARS=18000
AI_LOCAL_LLAMA_THREADS=1
AI_LOCAL_LLAMA_BATCH_SIZE=32
AI_LOCAL_LLAMA_UBATCH_SIZE=16
AI_LOCAL_LLAMA_MAX_CONCURRENT_REQUESTS=1
AI_LOCAL_LLAMA_PRELOAD_ON_STARTUP=false
AI_LOCAL_LLAMA_FORCE_SINGLE_THREAD_ON_WEAK=true
AI_LOCAL_LLAMA_NATIVE_SKIP_WARMUP=true
AI_LOCAL_LLAMA_NATIVE_DISABLE_FIT=true
AI_LOCAL_LLAMA_UNLOAD_AFTER_IDLE_MS=120000
AI_LOCAL_LLAMA_GPU_LAYERS=0

AI_SEO_ARTICLE_MAX_TOKENS=1536
AI_SEO_LOCALE_TRANSLATE_MAX_TOKENS=768
AI_EMBEDDING_PROVIDER=hash
AI_EMBEDDING_LLAMA_ENABLED=false
AI_EMBEDDING_HASH_DIMENSIONS=128
AI_EMBEDDING_HASH_FALLBACK_ENABLED=true

AI_LOCAL_PROMPT_SLOT_ACTIVE_EDITOR_CHARS=14000
AI_LOCAL_PROMPT_SLOT_RAG_CONTEXT_CHARS=2800
AI_CODE_STREAM_LOCAL_PROVIDER_MAX_PROMPT_CHARS=32000
AI_CODE_STREAM_MAX_PROMPT_CHARS=36000

AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_TOP_K=3
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_MAX_CHARS=2800
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ADAPTIVE_MAX_MAX_CHARS=2800

AI_ORCHESTRATION_MULTIMODAL_VISION_ENABLED=false
AI_ORCHESTRATION_MULTIMODAL_VISION_ENDPOINT=http://127.0.0.1:8090/v1/chat/completions
AI_ORCHESTRATION_MULTIMODAL_LOCAL_ONLY_REQUIRE_VISION=false

AI_MEDIA_RENDER_ENABLED=false
AI_MEDIA_CHARACTER_ENABLED=false
AI_MEDIA_CHARACTER_MODEL_AUTO_DOWNLOAD=false

# Guest web chat — 5GB anti overload (Socket.IO lane 4b)
AI_GUEST_CHAT_MAX_CONCURRENT=1
AI_GUEST_CHAT_MAX_OUTPUT_TOKENS=96
AI_GUEST_CHAT_PER_GUEST_COOLDOWN_MS=60000
AI_GUEST_CHAT_SKIP_WHEN_WORKER_BUSY=true
AI_GUEST_CHAT_MIN_FREE_HEAP_MB=256
AI_GUEST_CHAT_MAX_PENDING_SCHEDULED=8

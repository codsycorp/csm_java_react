# PROFILE: MacBook Pro M1 16GB — dev + render video local
#
# Dev (từ thư mục backend/):
#   set -a && source ../config.local-m1.env && set +a && mvn spring-boot:run
#
# Phù hợp: SEO, code AI, Character Director (Lane 5), ONNX rembg, FFmpeg.
# KHÔNG phù hợp: ComfyUI LTX I2V, SadTalker (cần GPU rời / RAM >32GB).

if [ -n "${BASH_SOURCE[0]:-}" ]; then
    _CSM_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -f "$_CSM_CONFIG_DIR/config.env" ]; then
        # shellcheck source=/dev/null
        source "$_CSM_CONFIG_DIR/config.env"
    fi
    unset _CSM_CONFIG_DIR
fi

CSM_LOCAL_PROFILE=m1-16gb
SPRING_PROFILES_ACTIVE=local,local-m1
SPRING_PROFILES_ACTIVE_OVERRIDE=prod,local-m1

AI_LOCAL_ONLY_ENABLED=true
AI_LOCAL_RUNTIME_TIER=balanced
AI_LOCAL_RUNTIME_WEAK_PROFILE_ENABLED=false

# JVM ~2.5GB — đủ Spring + ONNX spike + FFmpeg (trên tổng 16GB)
HEAP_SIZE=2560m
HEAP_INIT=512m

# Single worker 1.5B Q8_0 — code + SEO + guest chat (PHẦN Q)
AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
AI_LOCAL_LLAMA_SEO_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
AI_LOCAL_LLAMA_SWAP_MODELS=false
AI_LOCAL_LLAMA_RUNTIME_PROFILE=balanced
AI_LOCAL_LLAMA_THREADS=4
AI_LOCAL_LLAMA_CONTEXT_WINDOW=12288
AI_LOCAL_LLAMA_MAX_TOKENS=1024
AI_SEO_ARTICLE_MAX_TOKENS=2048
AI_SEO_LOCALE_TRANSLATE_MAX_TOKENS=1024
AI_SEO_ARTICLE_TARGET_WORDS_VI=350-500
AI_LOCAL_LLAMA_MAX_CONCURRENT_REQUESTS=1
AI_LOCAL_LLAMA_PRELOAD_ON_STARTUP=true

# Embedding nhẹ
AI_EMBEDDING_PROVIDER=hash
AI_EMBEDDING_HASH_DIMENSIONS=128

# Vision — sidecar :8090 (in-JVM SmolVLM tắt trên M1; bật khi chạy ./scripts/start-ai-local-vision.sh)
AI_ORCHESTRATION_MULTIMODAL_VISION_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_VISION_NATIVE_ENABLED=false
AI_ORCHESTRATION_MULTIMODAL_VISION_ENDPOINT=http://127.0.0.1:8090/v1/chat/completions
AI_ORCHESTRATION_MULTIMODAL_VISION_TIMEOUT_MS=12000

# Lane 5 S3 — TTS + talking-head bundled trong backend Java (không cần sidecar Python)
AI_MEDIA_RENDER_ENABLED=true
AI_MEDIA_RENDER_DEFAULT_ENGINE=talking_presenter
AI_MEDIA_TTS_VOICE=Linh
AI_MEDIA_RENDER_MAX_DURATION_SEC=30
AI_MEDIA_STORYBOARD_MAX_SCENES=5
AI_MEDIA_CHARACTER_ENABLED=true
AI_MEDIA_CHARACTER_MODEL_AUTO_DOWNLOAD=true

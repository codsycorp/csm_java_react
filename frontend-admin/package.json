{
	"name": "csm-frontend-admin",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@9.15.4",
	"description": "CSM standalone admin frontend",
	"author": "Nhật Anh",
	"license": "MIT",
	"homepage": "https://github.com/condorheroblog/react-antd-admin/blob/main/README.md",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/condorheroblog/react-antd-admin.git"
	},
	"bugs": {
		"url": "https://github.com/condorheroblog/react-antd-admin/issues"
	},
	"imports": {
		"#*": "./*"
	},
	"scripts": {
		"clean": "rm -rf node_modules dist && pnpm install",
		"dev": "vite --host",
		"build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
		"build:analyze": "NODE_OPTIONS=--max-old-space-size=8192 vite build --mode analyze",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"spa-github-index-page": "node ./scripts/spa-github-index-page.mjs",
		"spa-github-404-page": "node ./scripts/spa-github-404-page.mjs",
		"analyzer": "vite-bundle-visualizer --output analyzer/stats.html",
		"eslint-config-inspector": "npx @eslint/config-inspector",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prepare": "simple-git-hooks",
		"test": "vitest"
	},
	"dependencies": {
		"@ant-design/icons": "^5.5.2",
		"@ant-design/pro-components": "^2.8.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.9",
		"@codemirror/lang-javascript": "^6.2.4",
		"@codemirror/lang-json": "^6.0.1",
		"@codemirror/lang-python": "^6.1.6",
		"@codemirror/lang-sql": "^6.8.0",
		"@codemirror/lang-xml": "^6.1.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@fullcalendar/core": "^6.1.4",
		"@fullcalendar/daygrid": "^6.1.4",
		"@fullcalendar/interaction": "^6.1.4",
		"@fullcalendar/list": "^6.1.4",
		"@fullcalendar/react": "^6.1.4",
		"@fullcalendar/timegrid": "^6.1.4",
		"@iconify/react": "^5.2.0",
		"@tanstack/react-query": "^5.64.1",
		"@types/xlsx": "^0.0.36",
		"@uiw/codemirror-theme-vscode": "^4.25.3",
		"@uiw/codemirror-themes": "^4.25.3",
		"@uiw/react-codemirror": "^4.25.2",
		"ahooks": "^3.8.4",
		"antd": "^5.23.1",
		"antd-img-crop": "^4.24.0",
		"antd-weekly-calendar": "^2.0.1",
		"dayjs": "^1.11.13",
		"docx2html": "^1.3.2",
		"docxtemplater": "^3.38.1",
		"docxtemplater-image-module-free": "^1.1.1",
		"echarts": "^5.6.0",
		"echarts-for-react": "^3.0.2",
		"framer-motion": "^11.18.0",
		"he": "^1.2.0",
		"html2pdf.js": "^0.10.2",
		"i18next": "^24.2.1",
		"jszip": "^3.10.1",
		"jszip-utils": "^0.1.0",
		"keepalive-for-react": "^3.0.8",
		"ky": "^1.7.4",
		"nprogress": "^0.2.0",
		"pizzip": "^3.1.7",
		"quill": "^2.0.3",
		"react": "18",
		"react-dom": "18",
		"react-error-boundary": "^5.0.0",
		"react-i18next": "^15.4.0",
		"react-jss": "^10.10.0",
		"react-quill": "^2.0.0",
		"react-router": "^7.1.1",
		"react-use": "^17.4.0",
		"simplebar-react": "^3.3.0",
		"socket.io-client": "2.4.0",
		"spin-delay": "^2.0.1",
		"styled-components": "^5.3.6",
		"tailwind-merge": "^2.6.0",
		"xlsx": "^0.18.5",
		"zustand": "^5.0.3"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^3.14.0",
		"@commitlint/cli": "^19.6.1",
		"@commitlint/config-conventional": "^19.6.0",
		"@eslint-react/eslint-plugin": "^1.23.2",
		"@eslint/config-inspector": "^1.0.0",
		"@faker-js/faker": "^9.3.0",
		"@svgr/plugin-jsx": "^8.1.0",
		"@svgr/plugin-svgo": "^8.1.0",
		"@tanstack/react-query-devtools": "^5.64.1",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/node": "^22.10.6",
		"@types/nprogress": "^0.2.3",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.1",
		"@types/socket.io-client": "^3.0.0",
		"@types/styled-components": "^5.1.26",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"clsx": "^2.1.1",
		"code-inspector-plugin": "^0.19.2",
		"eslint": "^9.18.0",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.18",
		"globals": "^15.14.0",
		"happy-dom": "^16.6.0",
		"lint-staged": "^15.3.0",
		"postcss": "^8.5.1",
		"simple-git-hooks": "^2.11.1",
		"tailwindcss": "^3.4.17",
		"terser": "^5.37.0",
		"typescript": "^5.7.3",
		"vite": "^6.0.7",
		"vite-bundle-visualizer": "^1.2.1",
		"vite-plugin-checker": "^0.8.0",
		"vite-plugin-compression": "^0.5.1",
		"vite-plugin-fake-server": "^2.2.0",
		"vite-plugin-svgr": "^4.3.0",
		"vitest": "^v3.0.0-beta.4"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged",
		"commit-msg": "npx commitlint --edit"
	},
	"lint-staged": {
		"*": [
			"eslint --fix"
		]
	}
}

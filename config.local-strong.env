# PROFILE: máy dev mạnh — KHÔNG deploy lên server yếu
#
# Dev (từ thư mục backend/):
#   set -a && source ../config.local-strong.env && set +a && mvn spring-boot:run
#
# File này tự nạp ../config.env (secrets) nếu có — không cần source riêng.

if [ -n "${BASH_SOURCE[0]:-}" ]; then
    _CSM_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -f "$_CSM_CONFIG_DIR/config.env" ]; then
        # shellcheck source=/dev/null
        source "$_CSM_CONFIG_DIR/config.env"
    fi
    unset _CSM_CONFIG_DIR
fi

CSM_LOCAL_PROFILE=strong
# Jar: prod + local-strong | mvn dev: local + local-strong (mvn ưu tiên SPRING_PROFILES_ACTIVE)
SPRING_PROFILES_ACTIVE_OVERRIDE=prod,local-strong
SPRING_PROFILES_ACTIVE=local,local-strong

# Keep local-only code/menu routing
AI_LOCAL_ONLY_ENABLED=true
AI_PROVIDER_FORCE_GEMINI=false
AI_ROUTER_SCORE_V2_MENU_JSON_CLOUD=false

# Strong dev machine — cùng worker 1.5B Q8_0 như M1/Linux (PHẦN Q)
# Tải: ./scripts/download-ai-local-models.sh strong
AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
AI_LOCAL_LLAMA_SEO_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
AI_LOCAL_LLAMA_SWAP_MODELS=false

# Keep embedding runtime explicit when sourcing only this file.
AI_EMBEDDING_PROVIDER=llama_cpp_embedding
AI_EMBEDDING_LLAMA_ENABLED=true
AI_LOCAL_LLAMA_EMBEDDING_MODEL_PATH=./csm_datas/ai_local/model/nomic-embed-text-v1.5.Q4_K_M.gguf
AI_EMBEDDING_LLAMA_THREADS=8
AI_EMBEDDING_LLAMA_CONTEXT_WINDOW=4096
AI_EMBEDDING_LLAMA_BATCH_SIZE=512
AI_EMBEDDING_LLAMA_UBATCH_SIZE=512

# Prompt slot caps for edit (Cursor-style — avoid 400k default from application.properties)
AI_LOCAL_PROMPT_SLOT_ACTIVE_EDITOR_CHARS=14000
AI_LOCAL_PROMPT_SLOT_RAG_CONTEXT_CHARS=4000
AI_LOCAL_PROMPT_SLOT_MEMORY_CHARS=1200
AI_LOCAL_PROMPT_SLOT_USER_REQUEST_CHARS=3200
AI_LOCAL_ORCHESTRATION_LARGE_CODE_REGION_PLAN_MAX_CHARS=22000

# 1.5B Q8_0 optimized settings (strong dev machine — nhiều thread/ctx hơn local-5gb)
AI_LOCAL_LLAMA_RUNTIME_PROFILE=max
AI_LOCAL_LLAMA_THREADS=4
AI_LOCAL_LLAMA_THREADS_RESERVE_FOR_SYSTEM=2
AI_LOCAL_LLAMA_BATCH_SIZE=128
AI_LOCAL_LLAMA_UBATCH_SIZE=64
AI_LOCAL_LLAMA_CONTEXT_WINDOW=8192
AI_LOCAL_LLAMA_MAX_TOKENS=768
AI_LOCAL_LLAMA_MAX_PROMPT_CHARS=64000
AI_LOCAL_LLAMA_MAX_CONCURRENT_REQUESTS=1
AI_LOCAL_LLAMA_PRELOAD_ON_STARTUP=true
AI_LOCAL_LLAMA_FORCE_SINGLE_THREAD_ON_WEAK=false
AI_LOCAL_LLAMA_TEMPERATURE=0.2
AI_LOCAL_LLAMA_TOP_P=0.9
AI_LOCAL_LLAMA_TOP_K=40

# Broad-analysis + step streaming quality (strong machine)
AI_LOCAL_ANALYZE_BROAD_DETECT_FAST_HEURISTIC_ENABLED=true
AI_LOCAL_ANALYZE_BROAD_DETECT_SKIP_LLM_MAX_REQUEST_CHARS=520
AI_LOCAL_ANALYZE_MAP_REDUCE_MIN_CODE_CHARS=30000
AI_LOCAL_AGENTIC_STEP_VERIFIER_ENABLED=true
AI_LOCAL_AGENTIC_STEP_VERIFIER_MIN_SCORE=46
AI_LOCAL_AGENTIC_STEP_VERIFIER_MAX_ANCHORS=6

# Strong machine: keep adaptive knobs configured but do not trigger weak throttling
AI_LOCAL_RUNTIME_WEAK_PROFILE_ENABLED=false
AI_LOCAL_RUNTIME_WEAK_PROFILE_CORES_THRESHOLD=2
AI_LOCAL_RUNTIME_WEAK_PROFILE_HEAP_GB_THRESHOLD=6
AI_LOCAL_RUNTIME_WEAK_PROFILE_LOCAL_PROVIDER_MAX_PROMPT_CHARS=26000
AI_LOCAL_RUNTIME_WEAK_PROFILE_MAP_REDUCE_MAX_CHUNKS=5
AI_LOCAL_RUNTIME_WEAK_PROFILE_MAP_REDUCE_CHUNK_CHARS=14000

# Prompt/context budgets for larger local analysis/edit sessions
AI_CODE_STREAM_MAX_PROMPT_CHARS=220000
AI_CODE_STREAM_MENU_MAX_PROMPT_CHARS=280000
AI_CODE_STREAM_LOCAL_PROVIDER_MAX_PROMPT_CHARS=120000
AI_CODE_STREAM_ROUTING_RETRY_DEFAULT_MAX_PROMPT_CHARS=140000
AI_CODE_STREAM_MAX_CURRENT_CODE_CHARS=140000

# Orchestration + multimodal retrieval (higher budget)
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_TOP_K=10
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_MAX_CHARS=10000
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_ASYNC_ENABLED=true

# Vision sidecar (SmolVLM2-500M or Qwen2-VL-2B) — start: ./scripts/start-ai-local-vision.sh 500m
AI_ORCHESTRATION_MULTIMODAL_VISION_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_VISION_ENDPOINT=http://127.0.0.1:8090/v1/chat/completions
AI_ORCHESTRATION_MULTIMODAL_VISION_TIMEOUT_MS=15000

# Local AI uses JSON textEdits contract (not cloud SEARCH/REPLACE-only)
AI_CODE_STREAM_EDIT_STRICT_SEARCH_REPLACE_ENABLED=false

# Edit pipeline (large DynamicCode — symbol micro → multi-slice → focused fallback)
AI_EDIT_LOCAL_SYMBOL_MICRO_FIRST_ENABLED=true
AI_EDIT_SURGICAL_MAX_LINE_SPAN=40
AI_EDIT_TASK_PLANNER_MULTI_SLICE_EXECUTION_ENABLED=true
AI_CONTEXT_INGESTION_LARGE_CODE_ENABLED=true
AI_CONTEXT_INGESTION_LARGE_CODE_THRESHOLD_CHARS=45000

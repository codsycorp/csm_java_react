# Local strong-machine overrides for mvn spring-boot:run
# Load this AFTER config.env

# Activate local strong Spring profile created in backend resources
SPRING_PROFILES_ACTIVE=local,local-strong

# Keep local-only code/menu routing
AI_LOCAL_ONLY_ENABLED=true

# Local llama.cpp for strong dev machine
AI_LOCAL_LLAMA_RUNTIME_PROFILE=max
AI_LOCAL_LLAMA_THREADS=6
AI_LOCAL_LLAMA_BATCH_SIZE=256
AI_LOCAL_LLAMA_UBATCH_SIZE=128
AI_LOCAL_LLAMA_CONTEXT_WINDOW=8192
AI_LOCAL_LLAMA_MAX_TOKENS=768
AI_LOCAL_LLAMA_MAX_PROMPT_CHARS=320000

# Prompt/context budgets for larger local analysis/edit sessions
AI_CODE_STREAM_MAX_PROMPT_CHARS=220000
AI_CODE_STREAM_MENU_MAX_PROMPT_CHARS=280000
AI_CODE_STREAM_LOCAL_PROVIDER_MAX_PROMPT_CHARS=120000
AI_CODE_STREAM_ROUTING_RETRY_DEFAULT_MAX_PROMPT_CHARS=140000
AI_CODE_STREAM_MAX_CURRENT_CODE_CHARS=140000

# Orchestration + multimodal retrieval (higher budget)
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_TOP_K=10
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_MAX_CHARS=10000
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_ASYNC_ENABLED=true

# Keep background noise low while developing
CACHE_WARMING_ENABLED=false

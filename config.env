# Control whether Local Assistant rebuilds full source index on application startup.
# Set to false to avoid scanning/indexing entire repo at startup and rely on dynamic ingestion only.
AI_LOCAL_ASSISTANT_REBUILD_ON_STARTUP=false

# When true, startup rebuild only indexes human-readable content (md, markdown, txt).
# JSON/YAML menu payloads are NOT indexed on startup and must be ingested when the user
# explicitly selects a program/menu (frontend should call execute-local-plan with
# applyDynamicIngestion=true and contextType=menu_json to persist menu JSON into Lucene).
AI_LOCAL_ASSISTANT_STARTUP_INDEX_ONLY_MARKDOWN=true
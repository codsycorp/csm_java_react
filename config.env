# Local llama.cpp model path (GGUF)
# Đường dẫn tương đối tính từ thư mục backend/ (chạy mvn spring-boot:run từ đó)
# Thay tên file nếu dùng model khác, không cần đổi prefix
AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q4_k_m.gguf
AI_LOCAL_ONLY_ENABLED=true
# Optional quantized candidates:
# - Q4_K_M balance tốt hơn cho máy yếu nhưng vẫn giữ chất lượng code ổn:
#   AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
# - Q2_K tiết kiệm RAM hơn nữa, hợp máy <2GB RAM hoặc khi cần ưu tiên tốc độ nạp:
#   AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q2_k.gguf

# Ultra-fast preset for 2 Core / 5GB RAM (optional)
# Uncomment after downloading this model file:
# AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
AI_LOCAL_LLAMA_CONTEXT_WINDOW=4096
# Weak/low-RAM preset: keep caps tight so local pipeline stays responsive.
AI_LOCAL_LLAMA_MAX_TOKENS=512
AI_LOCAL_LLAMA_MAX_PROMPT_CHARS=120000
AI_LOCAL_LLAMA_THREADS=1
# Phase 5: Weak-machine preset - safer batch sizes to avoid OOM/thrash
AI_LOCAL_LLAMA_BATCH_SIZE=32
AI_LOCAL_LLAMA_UBATCH_SIZE=16
AI_LOCAL_LLAMA_TEMPERATURE=0.1
AI_LOCAL_LLAMA_TOP_P=0.8
AI_LOCAL_LLAMA_TOP_K=24
AI_LOCAL_LLAMA_RUNTIME_PROFILE=conservative
AI_LOCAL_LLAMA_THREADS_RESERVE_FOR_SYSTEM=1
AI_LOCAL_LLAMA_CIRCUIT_FAILURE_THRESHOLD=5
AI_LOCAL_LLAMA_CIRCUIT_COOLDOWN_MS=300000
AI_LOCAL_LLAMA_CIRCUIT_HARD_COOLDOWN_MS=900000
AI_CODE_STREAM_CONTEXT_FOCUSED_SNIPPETS_ENABLED=true
AI_CODE_STREAM_CONTEXT_FOCUSED_SNIPPETS_THRESHOLD_CHARS=24000
AI_CODE_STREAM_CONTEXT_FOCUSED_SNIPPETS_MAX_TOTAL_CHARS=8000
AI_CODE_STREAM_CONTEXT_FOCUSED_SNIPPETS_MAX_KEYWORD_HITS=5
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_ENABLED=true
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_THRESHOLD_CHARS=90000
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_MAX_WINDOWS=6
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_WINDOW_CHARS=2200
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_STEP_CHARS=14000
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_CPU_LOAD_THRESHOLD=0.8
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_BUSY_MAX_WINDOWS=3
AI_CODE_STREAM_ANALYZE_SLIDING_WINDOW_BUSY_LLAMA_INFLIGHT_THRESHOLD=1
AI_LOCAL_LLAMA_SYSTEM_PROMPT="You are a code-string-first assistant. Treat currentCode as the primary source of truth, use cursorLine and nearby context as the first anchor, do not assume a file path exists, and ask only narrowly scoped follow-up questions when needed. Keep answers brief and factual: what you checked, what you found, and the next step. Never repeat points you have already stated."

# Disable language alignment re-pass: avoids second LLM call with small token cap producing empty output
AI_LOCAL_ANALYZE_LANGUAGE_ALIGNMENT_ENABLED=false

# Dynamic memory from multimodal scanner (temporary Lucene context)
AI_BUSINESS_MEMORY_DYNAMIC_ENABLED=true
AI_BUSINESS_MEMORY_DYNAMIC_SOURCE_PREFIX=dyn_ctx_
AI_BUSINESS_MEMORY_DYNAMIC_MAX_AGE_MS=1800000
AI_BUSINESS_MEMORY_DYNAMIC_MAX_SOURCES=48
AI_BUSINESS_MEMORY_WRITE_LOCK_RETRIES=4
AI_BUSINESS_MEMORY_WRITE_LOCK_BACKOFF_MS=45

# Multi-modal scanner pipeline (JSON + image metadata, local-first)
AI_ORCHESTRATION_MULTIMODAL_SCANNER_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_JSON_CHARS=160000
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_IMAGE_BASE64_CHARS=2500000
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_DECODE_BYTES=5000000
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_JSON_KEY_SAMPLES=18
AI_ORCHESTRATION_MULTIMODAL_SCANNER_CONTEXT_MAX_CHARS=16000
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_MAX_MARKDOWN_CHARS=18000
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_ASYNC_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_TOP_K=6
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_MAX_CHARS=5000
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ADAPTIVE_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ADAPTIVE_MIN_TOP_K=3
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ADAPTIVE_MAX_TOP_K=8
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ADAPTIVE_MIN_MAX_CHARS=1800
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ADAPTIVE_MAX_MAX_CHARS=7600
AI_ORCHESTRATION_MULTIMODAL_LOCAL_ONLY=true
AI_ORCHESTRATION_MULTIMODAL_LOCAL_ONLY_REQUIRE_VISION=false

# Conversation context truncation (2-3 recent turns on weak machine)
AI_CONVERSATION_CONTEXT_RECENT_FULL_TURNS_PER_SCOPE=3
AI_CONVERSATION_CONTEXT_OLDER_SUMMARY_TURNS_PER_SCOPE=6
AI_CONVERSATION_CONTEXT_OPTIMIZED_WINDOW_RECENT_TURNS=3
AI_CONVERSATION_CONTEXT_SUMMARY_RECENT_TURNS=3

# Optional local VLM endpoint (Moondream2 / Qwen2-VL wrapper)
# Keep disabled by default on weak machines.
AI_ORCHESTRATION_MULTIMODAL_VISION_ENABLED=false
AI_ORCHESTRATION_MULTIMODAL_VISION_ENDPOINT=
AI_ORCHESTRATION_MULTIMODAL_VISION_TIMEOUT_MS=6000
# Suggested local VLM binaries for weak machine:
# - moondream2-q4_k_m.gguf
# - qwen2-vl-2b-instruct-q4_k_m.gguf
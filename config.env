# Local llama.cpp model path (GGUF)
# Đường dẫn tương đối tính từ thư mục backend/ (chạy mvn spring-boot:run từ đó)
# Thay tên file nếu dùng model khác, không cần đổi prefix
AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q4_k_m.gguf
AI_LOCAL_ONLY_ENABLED=true
AI_EMBEDDING_PROVIDER=llama_cpp_embedding
AI_EMBEDDING_LLAMA_ENABLED=true
# Ưu tiên dùng GGUF embedding riêng; qwen2.5-coder chỉ là fallback tạm thời, không tối ưu cho retrieval.
# Gợi ý theo thứ tự ưu tiên cho bài toán tiếng Việt + code + menu/business text:
# 1. BGE-M3 GGUF: mạnh nhất cho truy hồi đa ngôn ngữ, hợp dữ liệu Việt/Anh + JSON/menu.
# 2. Nomic-Embed-Text v1.5 GGUF: ổn cho text/code tổng quát, nhẹ hơn, dễ chạy trên máy yếu.
# 3. BGE-small-en / BGE-base-en GGUF: chỉ nên dùng khi dữ liệu chủ yếu là code/English, không ưu tiên tiếng Việt.
# Sau khi tải model, đặt file vào backend/csm_datas/ai_local/model/ rồi cập nhật biến dưới đây.
AI_LOCAL_LLAMA_EMBEDDING_MODEL_PATH=./csm_datas/ai_local/model/nomic-embed-text-v1.5.Q4_K_M.gguf
AI_EMBEDDING_HASH_DIMENSIONS=128
AI_EMBEDDING_HASH_FALLBACK_ENABLED=true
# Optional quantized candidates:
# - Q4_K_M balance tốt hơn cho máy yếu nhưng vẫn giữ chất lượng code ổn:
#   AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
# - Q2_K tiết kiệm RAM hơn nữa, hợp máy <2GB RAM hoặc khi cần ưu tiên tốc độ nạp:
#   AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q2_k.gguf

# Ultra-fast preset for 2 Core / 5GB RAM (optional)
# Uncomment after downloading this model file:
# AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
AI_LOCAL_LLAMA_CONTEXT_WINDOW=8192
# Weak/low-RAM preset (5GB RAM, 2 cores): balanced profile cho prompt ~29K, 512 token output
AI_LOCAL_LLAMA_MAX_TOKENS=512
AI_LOCAL_LLAMA_MAX_PROMPT_CHARS=120000
AI_LOCAL_LLAMA_THREADS=2
# batch=64/ubatch=32: throughput tốt hơn, vẫn an toàn ở 5GB RAM
AI_LOCAL_LLAMA_BATCH_SIZE=64
AI_LOCAL_LLAMA_UBATCH_SIZE=32
AI_LOCAL_LLAMA_TEMPERATURE=0.1
AI_LOCAL_LLAMA_TOP_P=0.8
AI_LOCAL_LLAMA_TOP_K=24
AI_LOCAL_LLAMA_RUNTIME_PROFILE=balanced
AI_LOCAL_LLAMA_THREADS_RESERVE_FOR_SYSTEM=1
AI_LOCAL_LLAMA_CIRCUIT_FAILURE_THRESHOLD=5
AI_LOCAL_LLAMA_CIRCUIT_COOLDOWN_MS=300000
AI_LOCAL_LLAMA_CIRCUIT_HARD_COOLDOWN_MS=900000
AI_CODE_STREAM_CONTEXT_FOCUSED_SNIPPETS_ENABLED=true

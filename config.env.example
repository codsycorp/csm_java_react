# Alibaba Cloud OSS Configuration
# Copy this file to config.env and fill in your actual credentials
# NEVER commit config.env to git!
#
# ── Chọn môi trường ─────────────────────────────────────────────────────────
# Dev (backend/):  set -a && source ../config.local-strong.env && set +a && mvn spring-boot:run
# Server (root):   ./run-server.sh
# Overlay tự nạp config.env khi source.

ACCESS_KEY_ID=your_access_key_id_here
ACCESS_KEY_SECRET=your_access_key_secret_here
REGION=cn-hongkong
OSSUTIL_CONFIG_PATH=./ossutilconfig
OSS_BUCKET_NAME=your_bucket_name
CDN_DOMAIN_NAME=your_domain.com

# Gemini API keys for AI Studio / LangChain4j Google AI Gemini integration
GEMINI_API_KEY=your_gemini_api_key
GEMINI_PRO_API_KEY=your_gemini_pro_api_key
GOOGLE_AI_GEMINI_API_KEY=your_google_ai_gemini_api_key

# Claude API key for LangChain4j Anthropic streaming integration
CLAUDE_API_KEY=your_claude_api_key

# Local llama.cpp model path (optional, for low-RAM local inference route)
# Đường dẫn tương đối tính từ thư mục backend/ — chỉ cần đổi tên file khi dùng model khác
AI_LOCAL_LLAMA_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
AI_LOCAL_LLAMA_SEO_MODEL_PATH=./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
# Optional quantized fallback (weak-machine only):
# - Q4_K_M balance tốt hơn cho máy yếu nhưng vẫn giữ chất lượng code ổn:
#   ./csm_datas/ai_local/model/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
# - Q2_K tiết kiệm RAM hơn nữa, hợp máy <2GB RAM hoặc khi cần ưu tiên tốc độ nạp:
#   ./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q2_k.gguf
AI_LOCAL_ONLY_ENABLED=true
AI_EMBEDDING_PROVIDER=llama_cpp_embedding
AI_EMBEDDING_LLAMA_ENABLED=true
# Prefer a dedicated embedding GGUF here; qwen2.5-coder is only a temporary fallback.
# Suggested order for Vietnamese + code + menu retrieval:
# 1. BGE-M3 GGUF
# 2. Nomic-Embed-Text v1.5 GGUF
# 3. BGE-small/base-en GGUF for mostly-English codebases
AI_LOCAL_LLAMA_EMBEDDING_MODEL_PATH=./csm_datas/ai_local/model/nomic-embed-text-v1.5.Q4_K_M.gguf
AI_EMBEDDING_HASH_DIMENSIONS=128
AI_EMBEDDING_HASH_FALLBACK_ENABLED=true

# AI Assistant business memory (Lucene vector) settings
AI_BUSINESS_MEMORY_ENABLED=true
AI_BUSINESS_MEMORY_INDEX_DIR=./csm_datas/ai_local/ai_business_memory
AI_BUSINESS_MEMORY_CHUNK_MAX_CHARS=2200
AI_BUSINESS_MEMORY_CHUNK_OVERLAP_CHARS=220
AI_BUSINESS_MEMORY_SEARCH_DEFAULT_K=6

# Dynamic (temporary) memory for multimodal scanner output
AI_BUSINESS_MEMORY_DYNAMIC_ENABLED=true
AI_BUSINESS_MEMORY_DYNAMIC_SOURCE_PREFIX=dyn_ctx_
AI_BUSINESS_MEMORY_DYNAMIC_MAX_AGE_MS=1800000
AI_BUSINESS_MEMORY_DYNAMIC_MAX_SOURCES=48

# Local agentic multimodal scanner (JSON + image metadata)
AI_ORCHESTRATION_MULTIMODAL_SCANNER_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_JSON_CHARS=160000
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_IMAGE_BASE64_CHARS=2500000
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_DECODE_BYTES=5000000
AI_ORCHESTRATION_MULTIMODAL_SCANNER_MAX_JSON_KEY_SAMPLES=18
AI_ORCHESTRATION_MULTIMODAL_SCANNER_CONTEXT_MAX_CHARS=16000
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_MAX_MARKDOWN_CHARS=18000
AI_ORCHESTRATION_MULTIMODAL_DYNAMIC_INGEST_ASYNC_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_ENABLED=true
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_TOP_K=6
AI_ORCHESTRATION_MULTIMODAL_SCOPE_RAG_MAX_CHARS=5000
AI_ORCHESTRATION_MULTIMODAL_LOCAL_ONLY=true
AI_ORCHESTRATION_MULTIMODAL_LOCAL_ONLY_REQUIRE_VISION=false

# ── Model stack (see CSM_AI_LOCAL_CURSOR_MASTER_BRIEF.md PHẦN Q) ─────────────
# Worker (JVM JNI):  ./csm_datas/ai_local/model/qwen2.5-coder-1.5b-instruct-q8_0.gguf
# Embedding strong: ./csm_datas/ai_local/model/nomic-embed-text-v1.5.Q4_K_M.gguf
# Vision weak 5GB:  SmolVLM2-256M-Video Q8_0 + mmproj (llama-server :8090)
# Vision strong:    SmolVLM2-500M-Video or Qwen2-VL-2B-Instruct-Q4_K_M.gguf
# Download:         ./scripts/download-ai-local-models.sh 5gb|strong
# Vision runtime:     ./scripts/start-ai-local-vision.sh

# Optional local vision: HTTP sidecar OR in-JVM native (Q.12)
# Sidecar: ./scripts/start-ai-local-vision.sh — set VISION_ENABLED=true + ENDPOINT
# Native:  VISION_NATIVE_ENABLED=true — no :8090; requires SmolVLM GGUF + mmproj on disk
AI_ORCHESTRATION_MULTIMODAL_VISION_ENABLED=false
AI_ORCHESTRATION_MULTIMODAL_VISION_ENDPOINT=http://127.0.0.1:8090/v1/chat/completions
AI_ORCHESTRATION_MULTIMODAL_VISION_TIMEOUT_MS=12000
AI_ORCHESTRATION_MULTIMODAL_VISION_NATIVE_ENABLED=false
AI_ORCHESTRATION_MULTIMODAL_VISION_MODEL_PATH=./csm_datas/ai_local/model/SmolVLM2-256M-Video-Instruct-Q8_0.gguf
AI_ORCHESTRATION_MULTIMODAL_VISION_MMPROJ_PATH=./csm_datas/ai_local/model/mmproj-SmolVLM2-256M-Video-Instruct-Q8_0.gguf
AI_ORCHESTRATION_MULTIMODAL_VISION_UNLOAD_AFTER_SCAN=true
AI_ORCHESTRATION_MULTIMODAL_VISION_SWAP_WORKER=true
AI_CONVERSATION_CONTEXT_OLDER_SUMMARY_TURNS_PER_SCOPE=6
AI_CONVERSATION_CONTEXT_OPTIMIZED_WINDOW_RECENT_TURNS=3
AI_CONVERSATION_CONTEXT_SUMMARY_RECENT_TURNS=3
